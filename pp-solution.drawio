                <mxCell id="idea_text" value="Envoy detects PPMissing BEFORE calling mediator.send() (which would block).  Returns LazyRemoteTensor instantly.&#10;The mediator thread skips remote modules without blocking, and only parks when it hits a real (local) module." style="text;fontSize=10;align=left;whiteSpace=wrap;spacingLeft=10;fontColor=#1B5E20;rounded=1;sketch=1;curveFitting=1;jiggle=2;" parent="idea_box" vertex="1">
