                <mxCell id="pf1" value="1. Mediator is a STATEFUL THREAD looping via tracer.iter[:], accumulating logits_list. Cannot serialize/ship thread state to another rank." style="text;fontSize=9;align=left;whiteSpace=wrap;spacingLeft=5;fontColor=#C62828;rounded=1;sketch=1;curveFitting=1;jiggle=2;" parent="push_fail" vertex="1">
                    <mxGeometry x="5" y="2" width="900" height="13" as="geometry"/>
                </mxCell>
                <mxCell id="pf2" value="2. Stage 0 needs its OWN values from previous steps (h from step 0 feeds step 1). Pushing everything away loses stage 0's accumulated state." style="text;fontSize=9;align=left;whiteSpace=wrap;spacingLeft=5;fontColor=#C62828;rounded=1;sketch=1;curveFitting=1;jiggle=2;" parent="push_fail" vertex="1">
                    <mxGeometry x="5" y="16" width="900" height="13" as="geometry"/>
                </mxCell>
                <mxCell id="pf3" value="3. Most interventions have NO cross-stage dependency. Pushing all variables wastes bandwidth every step." style="text;fontSize=9;align=left;whiteSpace=wrap;spacingLeft=5;fontColor=#C62828;rounded=1;sketch=1;curveFitting=1;jiggle=2;" parent="push_fail" vertex="1">
